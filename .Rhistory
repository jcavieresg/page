set.seed(123)
#===================================
# SHEPP-LOGAN PHANTOM
#===================================
shepp_logan_time <- function(n = 32, t = 0) {
res  <- seq(-1, 1, length.out = n)
grid <- expand.grid(x = res, y = res)
E <- matrix(c(
1.0,  .6900, .9200,  0.00,   0.0000,   0,
-0.8,  .6624, .8740,  0.00,  -0.0184,   0,
-0.2,  .1100, .3100,  0.22,   0.0000, -18,
-0.2,  .1600, .4100, -0.22,   0.0000,  18,
0.1,  .2100, .2500,  0.00,   0.3500,   0,
0.1,  .0460, .0460,  0.00,   0.1000,   0,
0.1,  .0460, .0460,  0.00,  -0.1000,   0,
0.1,  .0460, .0230, -0.08,  -0.6050,   0,
0.1,  .0230, .0230,  0.00,  -0.6050,   0,
0.1,  .0230, .0460,  0.06,  -0.6050,   0
), ncol = 6, byrow = TRUE)
# Smooth time-varying perturbations
E[, 4] <- E[, 4] + 0.02 * sin(t / 3)   # x-center drift
E[, 5] <- E[, 5] + 0.02 * cos(t / 4)   # y-center drift
E[, 1] <- E[, 1] * (1 + 0.05 * sin(t / 5))  # amplitude modulation
phantom_vec <- numeric(n * n)
for (k in seq_len(nrow(E))) {
A  <- E[k,1]; a  <- E[k,2]; b  <- E[k,3]
x0 <- E[k,4]; y0 <- E[k,5]
phi <- E[k,6] * pi / 180
cp  <- cos(phi); sp <- sin(phi)
xr <-  (grid$x - x0) * cp + (grid$y - y0) * sp
yr <- -(grid$x - x0) * sp + (grid$y - y0) * cp
mask <- (xr^2 / a^2 + yr^2 / b^2) <= 1
phantom_vec[mask] <- phantom_vec[mask] + A
}
matrix(phantom_vec, n, n)
}
#====================================
# PHANTOM SEQUENCE & NORMALISATION
#====================================
n_grid  <- 32
N_t     <- 8
t_seq   <- seq(0, pi, length.out = N_t)
s1_grid <- seq(-1, 1, length.out = n_grid)
s2_grid <- s1_grid
phantom_raw <- lapply(t_seq, shepp_logan_time, n = n_grid)
all_vals    <- unlist(phantom_raw)
min_val     <- min(all_vals)
max_val     <- max(all_vals)
phantom_list <- lapply(phantom_raw, function(mat)
as.vector((mat - min_val) / (max_val - min_val)))
# Visualise true sequence
par(mfrow = c(2, 4), mar = c(1, 1, 2, 1))
for (ti in seq_len(N_t))
image(s1_grid, s2_grid,
matrix(phantom_list[[ti]], n_grid, n_grid),
col  = gray.colors(256, start = 0, end = 1),
axes = FALSE, main = paste0("True t=", ti))
N_angles
ds       <- s1_grid[2] - s1_grid[1]
rmax     <- sqrt(2)
det_locs <- seq(-rmax, rmax, by = ds)
N_angles <- ceiling(pi / 2 * n_grid)
angles   <- seq(0, pi, length.out = N_angles + 1)[-(N_angles + 1)]
N_angles
angles
