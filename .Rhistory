library(plotly)
#------------------------------------------------------
# Simulate a GRF on a regular grid and plot in 3D
#------------------------------------------------------
set.seed(42)
# Grid
N_grid  <- 40
grid_1d <- seq(0, 1, length.out = N_grid)
grid    <- as.matrix(expand.grid(s1 = grid_1d, s2 = grid_1d))
# Matérn covariance
matern_cov <- function(coords1, coords2 = NULL, nu = 1, range, sigma2 = 1) {
if (is.null(coords2)) coords2 <- coords1
n1 <- nrow(coords1); n2 <- nrow(coords2)
D  <- as.matrix(dist(rbind(coords1, coords2)))[1:n1, (n1+1):(n1+n2), drop = FALSE]
D[D == 0] <- 1e-10
s  <- sqrt(2 * nu) * D / range
C  <- (2^(1 - nu)) / gamma(nu) * s^nu * besselK(s, nu)
if (n1 == n2 && isTRUE(all.equal(coords1, coords2))) diag(C) <- 1
sigma2 * C
}
# Simulate U(s) ~ GP(0, σ² C) via Cholesky
Sigma   <- matern_cov(grid, nu = 1, range = 0.3, sigma2 = 1)
diag(Sigma) <- diag(Sigma) + 1e-9
U       <- as.vector(t(chol(Sigma)) %*% rnorm(N_grid^2))
# Reshape to matrix for surface plot
Z <- matrix(U, nrow = N_grid, ncol = N_grid)
# 3D surface with plotly
plot_ly(x = grid_1d, y = grid_1d, z = Z, type = "surface",
colorscale = "RdBu", reversescale = TRUE,
contours = list(z = list(show = TRUE, usecolormap = TRUE,
highlightcolor = "#fff", project = list(z = TRUE)))) |>
layout(
title  = "Gaussian Random Field — Matérn covariance (ν = 1, ℓ = 0.3)",
scene  = list(
xaxis = list(title = "s1"),
yaxis = list(title = "s2"),
zaxis = list(title = "U(s)"),
camera = list(eye = list(x = 1.6, y = -1.6, z = 0.8))
)
)
# Simulate U(s) ~ GP(0, σ² C)
Sigma       <- matern_cov(grid, nu = 1, range = 0.3, sigma2 = 1)
diag(Sigma) <- diag(Sigma) + 1e-9
U           <- as.vector(t(chol(Sigma)) %*% rnorm(N_grid^2))
# Data frame for ggplot
df <- data.frame(s1 = grid[, "s1"], s2 = grid[, "s2"], U = U)
# Plot
ggplot(df, aes(s1, s2, z = U)) +
metR::geom_contour_fill(aes(fill = after_stat(level)), bins = 14) +
metR::geom_contour2(colour = "white", alpha = 0.35, size = 0.3, bins = 14) +
scale_fill_distiller(palette = "RdBu", direction = -1,
name = expression(U(bold(s)))) +
coord_equal() +
theme_bw(base_size = 12) +
theme(panel.grid = element_blank()) +
labs(title    = "Gaussian Random Field — Matérn covariance",
subtitle = expression(nu == 1 ~ "  range = 0.3  " ~ sigma^2 == 1),
x        = expression(s[1]),
y        = expression(s[2]))
